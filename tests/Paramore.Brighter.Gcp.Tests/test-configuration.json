{
  "Namespace": "Paramore.Brighter.Gcp.Tests",
  "MessagingGateways": {
    "Pull": {
      "Publication": "Paramore.Brighter.MessagingGateway.GcpPubSub.GcpPublication",
      "Subscription": "Paramore.Brighter.MessagingGateway.GcpPubSub.GcpPubSubSubscription",
      "MessageGatewayProvider": "Paramore.Brighter.Gcp.Tests.MessagingGateway.GcpPullMessageGatewayProvider",
      "Category": "GcpPubSub",
      "CollectionName": "Pull",
      "HasSupportToPublishConfirmation": false,
      "HasSupportToDeadLetterQueue": true,
      "HasSupportToDelayedMessages": false,
      "HasSupportToPartitionKey": false,
      "HasSupportToValidateBrokerExistence": true,
      "HasSupportToRequeue": true,
      "ReceiveMessageTimeoutInMilliseconds": 2000
    },
    "PullOrdering": {
      "Publication": "Paramore.Brighter.MessagingGateway.GcpPubSub.GcpPublication",
      "Subscription": "Paramore.Brighter.MessagingGateway.GcpPubSub.GcpPubSubSubscription",
      "MessageGatewayProvider": "Paramore.Brighter.Gcp.Tests.MessagingGateway.GcpPullOrderingMessageGatewayProvider",
      "MessageBuilder": "FifoMessageBuilder",
      "Category": "GcpPubSub",
      "CollectionName": "PullOrdering",
      "HasSupportToPublishConfirmation": false,
      "HasSupportToDeadLetterQueue": true,
      "HasSupportToDelayedMessages": false,
      "HasSupportToPartitionKey": true,
      "HasSupportToValidateBrokerExistence": true,
      "HasSupportToRequeue": true,
      "ReceiveMessageTimeoutInMilliseconds": 2000
    },
    "Stream": {
      "Publication": "Paramore.Brighter.MessagingGateway.GcpPubSub.GcpPublication",
      "Subscription": "Paramore.Brighter.MessagingGateway.GcpPubSub.GcpPubSubSubscription",
      "MessageGatewayProvider": "Paramore.Brighter.Gcp.Tests.MessagingGateway.GcpStreamMessageGatewayProvider",
      "Category": "GcpPubSub",
      "CollectionName": "Stream",
      "HasSupportToPublishConfirmation": false,
      "HasSupportToDeadLetterQueue": true,
      "HasSupportToDelayedMessages": false,
      "HasSupportToPartitionKey": false,
      "HasSupportToValidateBrokerExistence": true,
      "HasSupportToRequeue": true,
      "ReceiveMessageTimeoutInMilliseconds": 2000
    },
    "StreamOrdering": {
      "Publication": "Paramore.Brighter.MessagingGateway.GcpPubSub.GcpPublication",
      "Subscription": "Paramore.Brighter.MessagingGateway.GcpPubSub.GcpPubSubSubscription",
      "MessageGatewayProvider": "Paramore.Brighter.Gcp.Tests.MessagingGateway.GcpStreamOrderingMessageGatewayProvider",
      "MessageBuilder": "FifoMessageBuilder",
      "Category": "GcpPubSub",
      "CollectionName": "StreamOrdering",
      "HasSupportToPublishConfirmation": false,
      // Requeue is disabled for StreamOrdering because GCP Pub/Sub streaming pull with message ordering pauses delivery for an ordering key 
      //  after NACK until the ack deadline expires (60s). This makes immediate requeue/redelivery impossible, breaking the requeue test assumptions 
      //  that work for Pull mode. PullOrdering already covers requeue + ordering key behavior.
      "HasSupportToDeadLetterQueue": true,
      "HasSupportToDelayedMessages": false,
      "HasSupportToPartitionKey": true,
      "HasSupportToValidateBrokerExistence": true,
      "HasSupportToRequeue": false,
      "ReceiveMessageTimeoutInMilliseconds": 2000,
    }
  },
  "Outboxes": {
    "Firestore": {
      "Transaction": "Paramore.Brighter.Firestore.FirestoreTransaction",
      "OutboxProvider": "FirestoreOutboxProvider",
      "Category": "Firestore",
      "CollectionName": "FirestoreOutbox"
    },
    "SpannerBinary": {
      "Transaction": "System.Data.Common.DbTransaction",
      "OutboxProvider": "SpannerBinaryOutboxProvider",
      "Category": "Spanner",
      "CollectionName": "SpannerBinaryOutbox"
    },
    "SpannerText": {
      "Transaction": "System.Data.Common.DbTransaction",
      "OutboxProvider": "SpannerTextOutboxProvider",
      "Category": "Spanner",
      "CollectionName": "SpannerTextOutbox"
    }
  }
}
